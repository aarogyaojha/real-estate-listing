datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String         @id @default(uuid())
  username       String         @unique
  passwordHash   String
  isAdmin        Boolean        @default(false)
  refreshTokens  RefreshToken[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Agent {
  id         String    @id @default(uuid())
  name       String
  email      String    @unique
  phone      String?
  agencyName String
  listings   Listing[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Listing {
  id            String        @id @default(uuid())
  title         String
  description   String
  price         Decimal       @db.Decimal(12, 2)
  suburb        String
  state         String
  postcode      String
  propertyType  PropertyType
  bedrooms      Int
  bathrooms     Int
  parkingSpaces Int           @default(0)
  landSizeSqm   Decimal?      @db.Decimal(10, 2)
  floorSizeSqm  Decimal?      @db.Decimal(10, 2)
  status        ListingStatus @default(ACTIVE)
  internalNotes String?
  agentId       String
  agent         Agent         @relation(fields: [agentId], references: [id])
  listedAt      DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([price])
  @@index([suburb])
  @@index([propertyType])
  @@index([bedrooms])
  @@index([bathrooms])
  @@index([status])
  @@index([agentId])
}

enum PropertyType {
  HOUSE
  APARTMENT
  TOWNHOUSE
  LAND
  COMMERCIAL
}

enum ListingStatus {
  ACTIVE
  UNDER_CONTRACT
  SOLD
  WITHDRAWN
}
