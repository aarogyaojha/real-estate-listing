datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

enum UserRole {
  ADMIN
  AGENT
  CUSTOMER
}

model User {
  id             String         @id @default(uuid())
  username       String         @unique
  passwordHash   String
  role           UserRole       @default(CUSTOMER)
  agent          Agent?
  refreshTokens  RefreshToken[]
  savedListings  SavedListing[]
  reviews        AgentReview[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Agent {
  id             String         @id @default(uuid())
  name           String
  email          String         @unique
  phone          String?
  agencyName     String
  bio            String?
  specialties    String[]
  suburbCoverage String[]
  userId         String?        @unique
  user           User?          @relation(fields: [userId], references: [id])
  listings       Listing[]
  reviews        AgentReview[]
  enquiries      Enquiry[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Listing {
  id            String        @id @default(uuid())
  title         String
  description   String
  price         Decimal       @db.Decimal(12, 2)
  suburb        String
  state         String
  postcode      String
  propertyType  PropertyType
  bedrooms      Int
  bathrooms     Int
  parkingSpaces Int           @default(0)
  landSizeSqm   Decimal?      @db.Decimal(10, 2)
  floorSizeSqm  Decimal?      @db.Decimal(10, 2)
  status        ListingStatus @default(ACTIVE)
  internalNotes String?
  agentId       String
  agent         Agent          @relation(fields: [agentId], references: [id])
  savedBy       SavedListing[]
  enquiries     Enquiry[]
  listedAt      DateTime       @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([price])
  @@index([suburb])
  @@index([propertyType])
  @@index([bedrooms])
  @@index([bathrooms])
  @@index([status])
  @@index([agentId])
}

enum PropertyType {
  HOUSE
  APARTMENT
  TOWNHOUSE
  LAND
  COMMERCIAL
}

enum ListingStatus {
  ACTIVE
  UNDER_CONTRACT
  SOLD
  WITHDRAWN
}

model SavedListing {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}

model Enquiry {
  id        String   @id @default(uuid())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId   String
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())
}

model AgentReview {
  id        String   @id @default(uuid())
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  @@unique([agentId, userId])
}
